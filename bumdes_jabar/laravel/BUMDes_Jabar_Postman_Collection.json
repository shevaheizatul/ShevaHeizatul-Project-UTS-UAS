            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Keripik Singkong", "type": "text" },
                { "key": "category_id", "value": "1", "type": "text" },
                { "key": "type", "value": "produk", "type": "text" },
                { "key": "price", "value": "25000", "type": "text" },
                { "key": "stock", "value": "50", "type": "text" },
                { "key": "description", "value": "Keripik singkong khas desa", "type": "text" }
