              "host": ["{{base_url}}"],
              "path": ["api", "products", "search"],
              "query": [
                { "key": "q", "value": "keripik" },
                { "key": "category_id", "value": "1" },
                { "key": "min_price", "value": "10000" },
                { "key": "max_price", "value": "50000" }
