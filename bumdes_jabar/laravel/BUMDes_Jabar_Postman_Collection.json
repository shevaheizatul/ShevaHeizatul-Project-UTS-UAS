{
  "info": {
    "name": "BUMDes Jabar API",
    "_postman_id": "2d4f1b9c-5a8b-4d3c-9f09-0a1d2e4efb98",
    "description": "Postman collection untuk API BUMDes Jabar (Laravel). Gunakan variabel environment {{base_url}} dan {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdillah Syafiq\",\n  \"email\": \"abdillah@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"Penjual\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"abdillah@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.environment.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Store",
      "item": [
        {
          "name": "Create Store",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store_name\": \"BUMDes Jabar\",\n  \"description\": \"Toko hasil desa\",\n  \"village\": \"Desa Sukamaju\",\n  \"district\": \"Kecamatan Sukajadi\",\n  \"city\": \"Kabupaten Bandung\",\n  \"phone\": \"081234567890\",\n  \"bank_name\": \"BCA\",\n  \"bank_account_number\": \"1234567890\",\n  \"bank_account_holder\": \"BUMDes Jabar\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/store",
              "host": ["{{base_url}}"],
              "path": ["api", "store"]
            }
          }
        },
        {
          "name": "Update Store",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Toko hasil desa Jawa Barat\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/store",
              "host": ["{{base_url}}"],
              "path": ["api", "store"]
            }
          }
        },
        {
          "name": "Get Store",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/store",
              "host": ["{{base_url}}"],
              "path": ["api", "store"]
            }
          }
        }
      ]
    },
    {
